{
  "name": "@acme/convex",
  "private": true,
  "type": "module",
  "exports": {
    "./api": {
      "types": "./src/_generated/api.d.ts",
      "default": "./src/_generated/api.js"
    },
    "./model": {
      "types": "./src/_generated/dataModel.d.ts"
    },
    "./types": "./src/validators.ts",
    "./privileges": "./src/privileges.ts",
    "./page-utils": "./src/pages/utils.ts",
    "./page-validators": "./src/pages/validators.ts"
  },
  "scripts": {
    "dev": "convex dev",
    "build": "convex deploy",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "setup": "convex dev --until-success",
    "logs": "convex logs"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config",
  "dependencies": {
    "@acme/files": "workspace:*",
    "convex": "catalog:",
    "convex-env": "^2.5.0",
    "convex-helpers": "catalog:",
    "uploadthing": "catalog:"
  }
}
